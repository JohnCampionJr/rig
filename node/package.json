{
  "name": "@jcamp/rig",
  "version": "1.5.0",
  "description": "A convention-first Node dev launcher — less typing, menu-driven, workspace-aware.",
  "type": "module",
  "bin": {
    "rig": "./dist/cli.js",
    "rig-node": "./dist/rig-node.js",
    "rig-net": "./dist/rig-net.js"
  },
  "files": [
    "dist",
    "rig.schema.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build:bin": "pnpm build && node scripts/build-binaries.mjs",
    "install:rig-dev": "bun scripts/install-rig-dev.ts",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "release:version": "changeset version && node scripts/sync-dotnet-version.mjs",
    "release:publish": "changeset publish"
  },
  "keywords": [
    "cli",
    "dev",
    "launcher",
    "monorepo",
    "workspace",
    "npm",
    "pnpm",
    "yarn",
    "bun"
  ],
  "license": "MIT",
  "author": "John Campion Jr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohnCampionJr/rig.git",
    "directory": "node"
  },
  "homepage": "https://github.com/JohnCampionJr/rig/tree/main/node#readme",
  "bugs": "https://github.com/JohnCampionJr/rig/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "gunshi": "^0.33.0",
    "package-manager-detector": "^1.6.0",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.17",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
